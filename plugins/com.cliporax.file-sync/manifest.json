{
  "id": "com.cliporax.file-sync",
  "name": "File Sync",
  "description": "Synchronize individual files and folder snapshots through an existing Cliporax cloud sync profile.",
  "version": "0.1.3",
  "author": {
    "name": "Cliporax",
    "url": "https://github.com/Cliporax/cliporax-plugin-market"
  },
  "license": "MIT",
  "homepage": "https://github.com/Cliporax/cliporax-plugin-market",
  "repository": "https://github.com/Cliporax/cliporax-plugin-market",
  "keywords": ["file", "folder", "sync", "cloud"],
  "type": "transform",
  "permissions": [
    {
      "permission": "ui:extension",
      "reason": "Add the File Sync tab and file item action.",
      "required": true
    },
    {
      "permission": "data:read",
      "reason": "Read the selected file clipboard item for the context-menu action.",
      "required": true
    },
    {
      "permission": "network:sync",
      "reason": "Use an existing Cliporax sync profile through controlled backend commands.",
      "required": true
    },
    {
      "permission": "system:file-read",
      "reason": "Create immutable snapshots of files selected by the user.",
      "required": true
    },
    {
      "permission": "system:file-write",
      "reason": "Materialize downloaded files in the managed Cliporax cache.",
      "required": true
    },
    {
      "permission": "clipboard:write",
      "reason": "Put downloaded local file paths on the system file clipboard.",
      "required": true
    }
  ],
  "extensions": [
    {
      "point": "card",
      "component": "FileSyncButton",
      "condition": "item.type === 'file'",
      "priority": 20
    },
    {
      "point": "content-tab",
      "component": "FileSyncView",
      "priority": 20
    }
  ],
  "compatibility": {
    "platforms": ["linux", "macos", "windows"]
  },
  "icon": "assets/icon.svg",
  "main": "main.js",
  "minAppVersion": "1.1.0",
  "market": {
    "author": "Cliporax",
    "type": "sync"
  }
}
