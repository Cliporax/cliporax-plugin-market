{
  "id": "com.cliporax.todo",
  "name": "TODO",
  "description": "Adds an independent local TODO list tab to Cliporax.",
  "version": "0.1.0",
  "author": {
    "name": "Cliporax"
  },
  "license": "MIT",
  "homepage": "https://github.com/Cliporax/cliporax-plugin-market",
  "repository": "https://github.com/Cliporax/cliporax-plugin-market",
  "keywords": ["todo", "tasks", "local", "utility"],
  "type": "utility",
  "permissions": [
    {
      "permission": "ui:extension",
      "reason": "Add the TODO list as an independent content tab.",
      "required": true
    },
    {
      "permission": "system:storage",
      "reason": "Store TODO items locally in browser plugin storage.",
      "required": true
    }
  ],
  "extensions": [
    {
      "point": "content-tab",
      "component": "TodoView",
      "priority": 40
    }
  ],
  "minAppVersion": "1.1.0",
  "compatibility": {
    "platforms": ["linux", "macos", "windows"]
  },
  "icon": "assets/icon.svg",
  "main": "main.js",
  "market": {
    "author": "Cliporax",
    "type": "utility"
  }
}
