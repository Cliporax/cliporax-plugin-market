{
  "id": "com.cliporax.todo",
  "name": "TODO",
  "description": "Adds an independent local TODO list tab to Cliporax.",
  "version": "0.1.1",
  "author": {
    "name": "Cliporax"
  },
  "license": "MIT",
  "homepage": "https://github.com/Cliporax/cliporax-plugin-market",
  "repository": "https://github.com/Cliporax/cliporax-plugin-market",
  "keywords": ["todo", "tasks", "local", "utility"],
  "type": "transform",
  "permissions": [
    {
      "permission": "ui:extension",
      "reason": "Add the TODO list as an independent content tab.",
      "required": true
    },
    {
      "permission": "system:storage",
      "reason": "Store TODO items locally in browser plugin storage.",
      "required": true
    },
    {
      "permission": "ui:context-menu",
      "reason": "Add a Move to TODO action to clipboard item context menus.",
      "required": true
    },
    {
      "permission": "data:read",
      "reason": "Read selected clipboard item text before converting it into a TODO.",
      "required": true
    },
    {
      "permission": "data:delete",
      "reason": "Remove source clipboard items after they are moved into TODO.",
      "required": true
    }
  ],
  "extensions": [
    {
      "point": "content-tab",
      "component": "TodoView",
      "icon": "list-todo",
      "priority": 40
    },
    {
      "point": "context-menu",
      "component": "MoveToTodoAction",
      "icon": "list-todo",
      "condition": "item.type === \"text\"",
      "priority": 80
    }
  ],
  "minAppVersion": "1.1.0",
  "compatibility": {
    "platforms": ["linux", "macos", "windows"]
  },
  "icon": "assets/icon.svg",
  "main": "main.js",
  "market": {
    "author": "Cliporax",
    "type": "utility"
  }
}
